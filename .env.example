# ── Frontend (Create React App requires the REACT_APP_ prefix) ───────────
# Optional. If left empty, the app runs in demo mode automatically —
# anyone can log in instantly using the demo accounts shown on the login
# screen, no Supabase project required.
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=

# ── Serverless functions (api/*.js, used by Ndembo chat & plant ID) ──────
# Required for the AI features (autodiagnóstico, identificação de plantas).
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# Optional. Improves the "ver foto real" lookup in api/plant-image.js.
# Get a free key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# ── EmailJS (Registar Saber page) ─────────────────────────────────────
# Required for "Registar Saber" to actually notify someone — without
# these, submitting the form shows an error instead of silently losing
# the data. Get these at https://www.emailjs.com (Email Services /
# Email Templates / Account → General → Public Key).
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=
